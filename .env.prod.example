# Production Environment Configuration
# Copy this file to .env.prod and fill in the values
# DO NOT commit .env.prod to version control

# ===================================
# Database Configuration
# ===================================
DB_USER=secretmanager
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=secretmanager

# ===================================
# Backend Configuration
# ===================================
LOG_LEVEL=info

# Authentication Provider (oauth or mock)
AUTH_PROVIDER=oauth

# JWT Configuration
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_RANDOM_STRING_64_CHARS_MINIMUM

# OAuth Configuration
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret
OAUTH_ISSUER_URL=https://your-oauth-provider.com
OAUTH_REDIRECT_URL=https://your-domain.com/api/auth/callback

# ===================================
# Frontend Configuration
# ===================================
API_URL=https://your-domain.com
NEXTAUTH_URL=https://your-domain.com
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_RANDOM_STRING_32_CHARS_MINIMUM

# ===================================
# Git Integration
# ===================================
GIT_REPO_URL=git@github.com:your-org/secrets-repo.git
GIT_BRANCH=main
GIT_AUTH_TYPE=ssh
GIT_AUTHOR_NAME=Secret Manager
GIT_AUTHOR_EMAIL=secretmanager@your-domain.com

# ===================================
# SOPS Encryption
# ===================================
SOPS_ENABLED=true
SOPS_ENCRYPT_TYPE=age

# ===================================
# Kubernetes Integration
# ===================================
# Drift detection interval (e.g., 300s, 5m, 1h)
DRIFT_CHECK_INTERVAL=300s
DRIFT_WEBHOOK_URL=https://your-webhook-url.com/drift-alert

# FluxCD configuration
FLUX_NAMESPACE=flux-system
FLUX_HELM_RELEASE=secret-manager

# ===================================
# Nginx Configuration
# ===================================
HTTP_PORT=80
HTTPS_PORT=443

# ===================================
# Volume Paths (for secrets)
# ===================================
# Path to AGE encryption keys directory
AGE_KEY_PATH=./prod-keys/age-keys

# Path to SSH keys directory (for Git authentication)
SSH_KEY_PATH=./prod-keys/ssh-keys

# Path to Kubernetes config directory
KUBECONFIG_PATH=./prod-keys/kubeconfig

# ===================================
# Optional: Monitoring & Logging
# ===================================
# SENTRY_DSN=https://your-sentry-dsn
# LOG_FORMAT=json
# METRICS_ENABLED=true
# METRICS_PORT=9090
