# Database Configuration
DATABASE_URL=postgres://dev:devpass@localhost:5432/secretmanager?sslmode=disable

# Server Configuration
PORT=8080
LOG_LEVEL=info

# Authentication
AUTH_PROVIDER=mock
JWT_SECRET=dev-secret-change-in-production

# SOPS Encryption
SOPS_AGE_KEY_FILE=/keys/age.txt

# Kubernetes Configuration
K8S_KUBECONFIG=

# Git Configuration (for secret publishing)
GIT_REPO_URL=git@github.com:yourorg/secrets-repo.git
GIT_BRANCH=main
GIT_REPO_PATH=/data/secrets-repo
GIT_AUTH_TYPE=ssh
GIT_SSH_KEY_PATH=/path/to/id_rsa
GIT_AUTHOR_NAME=Secret Manager
GIT_AUTHOR_EMAIL=secret-manager@example.com

# OR for token auth:
# GIT_AUTH_TYPE=token
# GIT_TOKEN=ghp_yourpersonalaccesstoken
