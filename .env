# Database
DATABASE_URL=postgresql://secretmgr:secretpass@postgres:5432/secretmanager?sslmode=disable

# JWT
JWT_SECRET=dev-secret-change-in-production-12345678901234567890

# Git Configuration
GIT_REPO_URL=file:///home/nk/secret-manager/dev-data/secrets-repo
GIT_REPO_PATH=/home/nk/secret-manager/dev-data/secrets-repo
GIT_BRANCH=master
GIT_AUTH_TYPE=none
GIT_AUTHOR_NAME=Secret Manager Bot
GIT_AUTHOR_EMAIL=bot@secret-manager.local

# SOPS Configuration
SOPS_ENABLED=true
SOPS_ENCRYPT_TYPE=age
SOPS_AGE_KEY_PATH=/home/nk/secret-manager/dev-data/age-keys/keys.txt
SOPS_CONFIG_PATH=/home/nk/secret-manager/dev-data/secrets-repo/.sops.yaml

# FluxCD/K8s (optional - for local testing without cluster)
K8S_KUBECONFIG=
FLUX_NAMESPACE=flux-system

# Drift Detection
DRIFT_CHECK_ENABLED=false
DRIFT_CHECK_INTERVAL=5m

# Server
PORT=8080
LOG_LEVEL=info
