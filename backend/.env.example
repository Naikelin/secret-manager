# Backend Environment Variables
DATABASE_URL=postgres://dev:devpass@localhost:5432/secretmanager?sslmode=disable
PORT=8080
LOG_LEVEL=debug
JWT_SECRET=dev-secret-change-in-production

# Git Configuration
GIT_REPO_PATH=/data/secrets-repo
GIT_BRANCH=main

# Kubernetes Configuration
K8S_KUBECONFIG=/root/.kube/config

# Authentication
AUTH_PROVIDER=mock

# SOPS Configuration
SOPS_ENCRYPT_TYPE=kms
SOPS_KMS_KEY_ARN=arn:aws:kms:us-east-1:000000000000:key/YOUR-KEY-ID-HERE
SOPS_CONFIG_PATH=/workspace/.sops.yaml

# AWS Configuration (LocalStack for dev, real AWS for prod)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# Remove AWS_ENDPOINT_URL for production (use IAM roles instead)
AWS_ENDPOINT_URL=http://localstack:4566
